{
  "name": "mgr",
  "version": "0.1.0",
  "description": "Markdown Game Runtime — a compiler for Prompt Programming",
  "type": "module",
  "bin": {
    "mgr": "dist/cli/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src",
    "mgr": "tsx src/cli/index.tsx"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PhuVinhAI/mgr.git"
  },
  "keywords": [
    "markdown",
    "prompt",
    "compiler",
    "llm",
    "game"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/PhuVinhAI/mgr/issues"
  },
  "homepage": "https://github.com/PhuVinhAI/mgr#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mdast": "^4.0.4",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/unist": "^3.0.3",
    "eslint": "^10.6.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.9.4",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "ink": "^7.1.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.1",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-table": "^3.1.0",
    "ink-text-input": "^6.0.0",
    "mdast-util-to-string": "^4.0.0",
    "meow": "^14.1.0",
    "picocolors": "^1.1.1",
    "react": "^19.2.7",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.4.3"
  }
}
